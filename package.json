{
  "name": "mcp_tldraw",
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:ws": "tsx watch server/ws-server.ts",
    "frontend": "npm run dev && npm run dev:ws",
    "canvas": "concurrently \"npm run dev\" \"npm run dev:ws\" \"npm run mcp-server\"",
    "server": "set DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector tsx src/mcp-server.ts",
    "build": "next build",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "mcp-server": "tsx src/mcp-server.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "next": "^15.0.0",
    "node-fetch": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tldraw": "^3.15.1",
    "tsx": "^4.19.0",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@modelcontextprotocol/inspector": "^0.15.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
